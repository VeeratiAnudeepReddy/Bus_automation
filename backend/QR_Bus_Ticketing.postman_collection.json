{
  "info": {
    "name": "QR Bus Ticketing System",
    "description": "API collection for QR Code-based Bus Ticketing System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Register User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"John Doe\"\n}"
        },
        "url": {
          "raw": "http://localhost:5001/api/register",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5001",
          "path": ["api", "register"]
        }
      }
    },
    {
