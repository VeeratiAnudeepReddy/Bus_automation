        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"<REPLACE_WITH_USER_ID>\",\n  \"amount\": 100\n}"
        },
        "url": {
          "raw": "http://localhost:5001/api/recharge",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5001",
          "path": ["api", "recharge"]
        }
